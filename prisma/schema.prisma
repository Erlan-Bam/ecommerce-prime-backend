generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  EDITOR
  MANAGER
  ADMIN
}

enum BonusType {
  INCREASE
  DECREASE
}

enum CouponType {
  FIXED
  PERCENTAGE
}

enum PaymentMethod {
  ROBOKASSA
  CASH
}

enum PaymentStatus {
  PENDING
  COMPLETED
  REFUNDED
}

enum SeoPageType {
  HOME
  CATEGORY
  PRODUCT
  STATIC
  BLOG
}

enum OrderStatus {
  PENDING
  PROCESSING
  CONFIRMED
  PAYED
  ASSEMBLED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum DeliveryMethod {
  PICKUP
  DELIVERY
}

model User {
  id         String   @id @default(uuid())
  email      String?  @unique
  phone      String?  @unique
  password   String?
  name       String
  telegramId String?  @unique
  avatar     String?
  role       Role     @default(USER)
  isBanned   Boolean  @default(false)
  totalSpent Decimal  @default(0) @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  bonuses    Bonus[]
  reviews    Review[]
  orders     Order[]
  orderItems OrderItem[]
  favorites  Favorite[]
}

model Category {
  id        String    @id @default(uuid())
  parentId  String?
  title     String
  slug      String    @unique
  description String?
  seoTitle  String?
  seoDescription String?
  seoH1     String?
  filterAttributes String[] @default([])
  image     String?
  isActive  Boolean   @default(true)
  sortOrder Int       @default(0)
  isMain    Boolean   @default(false)
  mainSortOrder Int   @default(0)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  parent    Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryChildren")
  products  ProductCategory[]
  seoCollections SeoCollection[]
  seoTagTiles SeoTagTile[]

  @@index([parentId])
  @@index([slug])
  @@index([isMain, mainSortOrder])
  @@index([isDeleted])
}

model Brand {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  logo      String?
  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]

  @@index([slug])
  @@index([isDeleted])
}

model Product {
  id          String    @id @default(uuid())
  brandId     String?
  variantGroupId String?
  name        String
  slug        String    @unique
  description String?
  seoTitle    String?
  seoDescription String?
  seoH1       String?
  price       Decimal   @db.Decimal(10, 2)
  oldPrice    Decimal?  @db.Decimal(10, 2)
  isActive    Boolean   @default(true)
  isOnSale    Boolean   @default(false)
  isPopular   Boolean   @default(false)
  viewCount   Int       @default(0)
  soldCount   Int       @default(0)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  variantColor String?
  variantMemory String?
  variantSim   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  brand       Brand?    @relation(fields: [brandId], references: [id])
  variantGroup ProductVariantGroup? @relation(fields: [variantGroupId], references: [id], onDelete: SetNull)
  categories  ProductCategory[]
  images      ProductImage[]
  attributes  ProductAttribute[]
  reviews     Review[]
  productStock ProductStock[]
  orderItems  OrderItem[]
  favorites   Favorite[]
  relatedProducts ProductRelation[] @relation("SourceRelatedProducts")
  relatedFromProducts ProductRelation[] @relation("TargetRelatedProducts")

  @@index([brandId])
  @@index([variantGroupId])
  @@index([slug])
  @@index([price])
  @@index([createdAt])
  @@index([isPopular])
  @@index([isActive, isOnSale])
  @@index([isDeleted])
  @@index([variantColor, variantMemory, variantSim])
}

model ProductVariantGroup {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]

  @@index([name])
}

model ProductCategory {
  id         String   @id @default(uuid())
  productId  String
  categoryId String
  isPrimary  Boolean  @default(false) 
  createdAt  DateTime @default(now())

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([productId, categoryId])
  @@index([productId])
  @@index([categoryId])
}

model ProductRelation {
  id              String   @id @default(uuid())
  sourceProductId String
  targetProductId String
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sourceProduct Product @relation("SourceRelatedProducts", fields: [sourceProductId], references: [id], onDelete: Cascade)
  targetProduct Product @relation("TargetRelatedProducts", fields: [targetProductId], references: [id], onDelete: Cascade)

  @@unique([sourceProductId, targetProductId])
  @@index([sourceProductId, sortOrder])
  @@index([targetProductId])
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductAttribute {
  id        String   @id @default(uuid())
  productId String
  name      String
  value     String
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([name, value])
}

model PickupWindow {
  id        String   @id @default(uuid())
  pointId   String
  startTime DateTime
  endTime   DateTime
  capacity  Int      @default(24)
  reserved  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pickupPoint PickupPoint @relation(fields: [pointId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@unique([pointId, startTime])
  @@index([pointId])
  @@index([startTime, endTime])
}

model OrderItem {
  id        String   @id @default(uuid())
  userId    String?
  sessionId String?
  orderId   Int?
  productId String
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  unitPrice Decimal? @db.Decimal(10, 2)
  variantKey String?
  variantLabel String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User?         @relation(fields: [userId], references: [id])
  session   GuestSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  order     Order?        @relation(fields: [orderId], references: [id])
  product   Product       @relation(fields: [productId], references: [id])

  @@unique([sessionId, productId, orderId])
  @@index([userId])
  @@index([sessionId])
  @@index([orderId])
  @@index([variantKey])
}

model Order {
  id           Int         @id @default(autoincrement())
  userId       String?
  sessionId    String?
  total        Decimal     @db.Decimal(10, 2)
  discount     Decimal     @default(0) @db.Decimal(10, 2)
  finalTotal   Decimal     @db.Decimal(10, 2)
  email        String?
  phone        String?
  buyer        String?
  status       OrderStatus @default(PENDING)
  deliveryMethod DeliveryMethod @default(DELIVERY)
  paymentMethod  PaymentMethod @default(CASH)
  address      String?
  entrance     String?
  comment      String?
  deliveryTime String?
  pointId      String?
  windowId     String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  couponId     String?
  bonusUsed    Decimal     @default(0) @db.Decimal(10, 2)
  bonusEarned  Decimal     @default(0) @db.Decimal(10, 2)
  bonusAccrualScheduledAt DateTime?
  bonusAccrualAvailableAt DateTime?
  bonusAccruedAt DateTime?

  user         User?          @relation(fields: [userId], references: [id])
  session      GuestSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  items        OrderItem[]
  pickupPoint  PickupPoint?  @relation(fields: [pointId], references: [id])
  pickupWindow PickupWindow? @relation(fields: [windowId], references: [id])
  coupon       Coupon?       @relation(fields: [couponId], references: [id])
  payment      Payment?
  bonuses      Bonus[]

  @@index([userId])
  @@index([sessionId])
  @@index([status])
  @@index([bonusAccrualAvailableAt, bonusAccruedAt])
  @@index([pointId])
  @@index([windowId])
  @@index([couponId])
}

model Payment {
  id        String   @id @default(uuid())
  orderId   Int      @unique
  amount    Decimal  @db.Decimal(10, 2)
  method    PaymentMethod
  status    PaymentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Review {
  id        String   @id @default(uuid())
  productId String
  userId    String?
  guestName String?  // For guest reviews
  rating    Int
  comment   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])

  @@unique([productId, userId])
  @@index([productId])
  @@index([rating])
}

model Bonus {
  id          Int       @id @default(autoincrement())
  userId      String
  orderId     Int?
  amount      Decimal   @db.Decimal(10, 2)
  type        BonusType
  description String?
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id])
  order       Order?    @relation(fields: [orderId], references: [id])

  @@index([userId])
  @@index([orderId])
  @@index([createdAt])
}

model PickupPoint {
  id               String   @id @default(uuid())
  name             String
  address          String
  coords           String   // "lat,lng" format
  workingSchedule  Json     // {"Пн": {"from": "09:00", "to": "18:00"}, ...}
  url              String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  productStock  ProductStock[]
  pickupWindows PickupWindow[]
  orders        Order[]

  @@index([isActive])
}

model ProductStock {
  id          String   @id @default(uuid())
  productId   String
  pointId     String
  sku         String
  stockCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  pickupPoint PickupPoint @relation(fields: [pointId], references: [id], onDelete: Cascade)

  @@unique([productId, pointId])
  @@index([productId])
  @@index([pointId])
  @@index([sku])
}

model ProductImportBatch {
  id                String               @id @default(uuid())
  fileName          String
  status            String               @default("PROCESSING")
  totalRows         Int                  @default(0)
  processedRows     Int                  @default(0)
  createdCount      Int                  @default(0)
  updatedCount      Int                  @default(0)
  skippedCount      Int                  @default(0)
  summary           Json?
  createdCategories Json?
  createdBrands     Json?
  completedAt       DateTime?
  undoneAt          DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  entries ProductImportEntry[]

  @@index([status, completedAt])
  @@index([createdAt])
}

model ProductImportEntry {
  id             String             @id @default(uuid())
  batchId        String
  productId      String
  action         String
  beforeSnapshot Json?
  afterUpdatedAt DateTime
  createdAt      DateTime           @default(now())

  batch ProductImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, productId])
  @@index([batchId])
  @@index([productId])
}

model Coupon {
  id         String     @id @default(uuid())
  code       String     @unique
  type       CouponType
  value      Decimal    @db.Decimal(10, 2)
  validFrom  DateTime
  validTo    DateTime
  usageLimit Int        @default(0) // 0 = unlimited
  usageCount Int        @default(0)
  isActive   Boolean    @default(true)
  isDeleted  Boolean    @default(false)
  deletedAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  orders     Order[]

  @@index([code])
  @@index([isActive])
  @@index([validFrom, validTo])
  @@index([isDeleted])
}

model GuestSession {
  id            String   @id @default(uuid())
  fingerprint   String   @unique // Device fingerprint hash
  userAgent     String?
  ipAddress     String?
  lastActiveAt  DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cartItems     OrderItem[]
  orders        Order[]

  @@index([fingerprint])
  @@index([lastActiveAt])
}

model Blog {
  id        String   @id @default(uuid())
  title     String
  text      String
  slug      String   @unique
  excerpt   String?  // Short description for blog list
  imageUrl  String?  // Featured image URL
  author    String   @default("Редакция Prime")
  readTime  String   @default("5 мин")
  tags      String[] @default([])
  meta      Json?    // SEO meta data: { description, keywords, ogImage, etc. }
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([isActive])
  @@index([createdAt])
}

model SeoTemplate {
  id                  String      @id @default(uuid())
  type                SeoPageType @unique
  titleTemplate       String?
  descriptionTemplate String?
  h1Template          String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model StaticPageSeo {
  id             String   @id @default(uuid())
  path           String   @unique
  name           String?
  title          String?
  seoTitle       String?
  seoDescription String?
  seoH1          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([path])
  @@index([isActive])
}

model RobotsSettings {
  id        String   @id
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SeoCollection {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  categoryId     String?
  brandIds       String[] @default([])
  minPrice       Decimal? @db.Decimal(10, 2)
  maxPrice       Decimal? @db.Decimal(10, 2)
  inStock        Boolean  @default(false)
  isOnSale       Boolean  @default(false)
  attributes     Json?
  sortBy         String?
  description    String?
  seoTitle       String?
  seoDescription String?
  seoH1          String?
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tagTiles SeoTagTile[]

  @@index([categoryId])
  @@index([isActive, sortOrder])
}

model SeoTagTile {
  id           String   @id @default(uuid())
  title        String
  image        String?
  categoryId   String?
  collectionId String?
  url          String?
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category   Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  collection SeoCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([collectionId])
  @@index([isActive, sortOrder])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}
